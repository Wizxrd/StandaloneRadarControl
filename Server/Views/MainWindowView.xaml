<Window x:Class="Server.Views.MainWindowView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Server.ViewModels"
        mc:Ignorable="d"
        Background="Black"
        Title="MainWindow"
        Width="425" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        d:DataContext="{d:DesignInstance local:MainWindowViewModel}">
    
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0" CornerRadius="0" CaptionHeight="0"/>
    </WindowChrome.WindowChrome>
    <Grid Name="MainWindowGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border x:Name="TitleBorder" Grid.Row="0" Height="25" Background="{DynamicResource TitleBarColor}" MouseDown="TitleBarMouseDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock
                    x:Name="TitleBarTextBlock"
                    Text="SRC Server"
                    Grid.Column="0"
                    Foreground="{DynamicResource TextColor}"
                    FontFamily="Consolas" FontWeight="Light" FontSize="12"
                    VerticalAlignment="Center"
                    Margin="10,0,0,0">
                </TextBlock>
                <Button
                    x:Name="MinimizeButton"
                    ToolTip="Minimize"
                    Grid.Column="2"
                    Width="37"
                    Style="{DynamicResource MinimizeButtonStyle}"
                    Click="MinimizeButtonClick">
                </Button>
                <Button
                    x:Name="CloseButton"
                    ToolTip="Close"
                    Grid.Column="3"
                    Width="37"
                    Style="{DynamicResource CloseButtonStyle}"
                    Click="CloseButtonClick">
                </Button>
            </Grid>
        </Border>
        <Border Grid.Row="1" Height="25"
                Background="{DynamicResource GrayBackground}"
                BorderBrush="{DynamicResource GrayBorder}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock
                    Text="Clients: 0"
                    Grid.Column="0"
                    Foreground="{DynamicResource YellowText}"
                    FontFamily="Consolas" FontWeight="Bold" FontSize="12"
                    VerticalAlignment="Center"
                    Margin="10,0,0,0">
                </TextBlock>
                <TextBlock
                    Text="Ping: 0.0ms"
                    Grid.Column="1"
                    Foreground="{DynamicResource YellowText}"
                    FontFamily="Consolas" FontWeight="Bold" FontSize="12"
                    VerticalAlignment="Center"
                    Margin="10,0,0,0">
                </TextBlock>
                <TextBlock
                    Text="FPS: 0"
                    Grid.Column="2"
                    Foreground="{DynamicResource YellowText}"
                    FontFamily="Consolas" FontWeight="Bold" FontSize="12"
                    VerticalAlignment="Center"
                    Margin="10,0,0,0">
                </TextBlock>
                <TextBlock
                    Name="PortTextBlock"
                    Grid.Column="3"
                    Foreground="{DynamicResource YellowText}"
                    FontFamily="Consolas" FontWeight="Bold" FontSize="12"
                    VerticalAlignment="Center"
                    Margin="10,0,0,0">
                    Port: <TextBlock Text="{Binding DataExportHandler.SrcExternalPort, Mode=OneWay}" />
                </TextBlock>
            </Grid>
        </Border>
        <Border Grid.Row="2" Background="{StaticResource GrayBackground}" BorderBrush="{DynamicResource GrayBorder}" BorderThickness="1,0,1,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="1" Margin="0,5,0,0">
                    <Grid>
                        <Button
                            Grid.Row="0"
                            FontFamily="Consolas" FontWeight="Bold" FontSize="12"
                            Content="Command"
                            Width="125" Height="25"
                            Margin="10,5,0,5"
                            Tag="-1"
                            Background="{DynamicResource GrayBackgroundLight}"
                            BorderBrush="{DynamicResource BlueBorder}"
                            Foreground="{DynamicResource TextColor}"
                            HorizontalAlignment="Left"
                            Template="{DynamicResource MainButtonTemplate}">
                        </Button>
                        <Button
                            Name="StartServerButton" Grid.Row="0"
                            FontFamily="Consolas" FontWeight="Bold" FontSize="12"
                            Width="125" Height="25"
                            Margin="0,5,0,5"
                            Tag="-1"
                            Background="{DynamicResource GrayBackgroundLight}"
                            BorderBrush="{DynamicResource BlueBorder}"
                            Foreground="{DynamicResource TextColor}"
                            HorizontalAlignment="Center"
                            Click="StartServerButtonClick"
                            Template="{DynamicResource MainButtonTemplate}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Content" Value="START"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ServerRunning}" Value="True">
                                            <Setter Property="Content" Value="STOP" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ServerRunning}" Value="False">
                                            <Setter Property="Content" Value="START" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button
                            Grid.Row="0"
                            FontFamily="Consolas" FontWeight="Bold" FontSize="12"
                            Content="Admin"
                            Width="125" Height="25"
                            Margin="0,5,10,5"
                            Tag="-1"
                            Background="{DynamicResource GrayBackgroundLight}"
                            BorderBrush="{DynamicResource BlueBorder}"
                            Foreground="{DynamicResource TextColor}"
                            HorizontalAlignment="Right"
                            Template="{DynamicResource MainButtonTemplate}">
                        </Button>
                    </Grid>
                </Border>
                <Border Grid.Row="2">
                    <Grid>
                        <TextBlock
                            FontFamily="Consolas" FontWeight="Bold" FontSize="12"
                            Text="Radar Export"
                            Margin="10,0,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource TextColor}">
                        </TextBlock>
                        <ComboBox
                            Width="125" Height="25"
                            Margin="0,5,10,5"
                            HorizontalAlignment="Right"
                            SelectedIndex="0"
                            Style="{StaticResource ComboBoxStyle}">
                            <ComboBoxItem>Global</ComboBoxItem>
                            <ComboBoxItem>Semi-Real</ComboBoxItem>
                            <ComboBoxItem>Real</ComboBoxItem>
                        </ComboBox>
                    </Grid>
                </Border>
                <Border Grid.Row="3">
                    <Grid>
                        <TextBlock
                            FontFamily="Consolas" FontWeight="Bold" FontSize="12"
                            Text="Ground Unit Export"
                            Margin="10,0,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource TextColor}">
                        </TextBlock>
                        <Button
                            FontFamily="Consolas" FontWeight="Bold" FontSize="12"
                            Content="Off"
                            Width="125" Height="25"
                            Margin="0,5,10,5"
                            Tag="-1"
                            Background="{DynamicResource GrayBackgroundLight}"
                            BorderBrush="{DynamicResource BlueBorder}"
                            Foreground="{DynamicResource TextColor}"
                            HorizontalAlignment="Right"
                            Template="{DynamicResource MainButtonTemplate}">
                        </Button>
                    </Grid>
                </Border>
                <Border Grid.Row="4">
                    <Grid>
                        <TextBlock
                            FontFamily="Consolas" FontWeight="Bold" FontSize="12"
                            Text="Naval Unit Export"
                            Margin="10,0,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource TextColor}">
                        </TextBlock>
                        <Button
                            FontFamily="Consolas" FontWeight="Bold" FontSize="12"
                            Content="Off"
                            Width="125" Height="25"
                            Margin="0,5,10,5"
                            Tag="-1"
                            Background="{DynamicResource GrayBackgroundLight}"
                            BorderBrush="{DynamicResource BlueBorder}"
                            Foreground="{DynamicResource TextColor}"
                            HorizontalAlignment="Right"
                            Template="{DynamicResource MainButtonTemplate}">
                        </Button>
                    </Grid>
                </Border>
                <Border Grid.Row="5">
                    <Grid>
                        <TextBlock
                            FontFamily="Consolas" FontWeight="Bold" FontSize="12"
                            Text="Simultaneous Connect"
                            Margin="10,0,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource TextColor}">
                        </TextBlock>
                        <Button
                            FontFamily="Consolas" FontWeight="Bold" FontSize="12"
                            Content="On"
                            Width="125" Height="25"
                            Margin="0,5,10,5"
                            Tag="-1"
                            Background="{DynamicResource GrayBackgroundLight}"
                            BorderBrush="{DynamicResource BlueBorder}"
                            Foreground="{DynamicResource TextColor}"
                            HorizontalAlignment="Right"
                            Template="{DynamicResource MainButtonTemplate}">
                        </Button>
                    </Grid>
                </Border>
                <Border Grid.Row="6">
                    <Grid>
                        <TextBlock
                            FontFamily="Consolas" FontWeight="Bold" FontSize="12"
                            Text="Max Red Controllers"
                            Margin="10,0,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource TextColor}">
                        </TextBlock>
                        <TextBox
                            Width="125" Height="24"
                            Text="10"
                            FontFamily="Consolas" FontWeight="Light" FontSize="12"
                            TextAlignment="Center" HorizontalAlignment="Right"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                            Background="{DynamicResource GrayBackgroundLight}"
                            BorderBrush="{DynamicResource BlueBorder}"
                            BorderThickness="1"
                            Margin="0,5,10,5"
                            Foreground="{DynamicResource TextColor}"
                            Style="{DynamicResource TextBoxStyle}">
                        </TextBox>
                    </Grid>
                </Border>
                <Border Grid.Row="7">
                    <Grid>
                        <TextBlock
                            FontFamily="Consolas" FontWeight="Bold" FontSize="12"
                            Text="Max Blue Controllers"
                            Margin="10,0,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource TextColor}">
                        </TextBlock>
                        <TextBox
                            Width="125" Height="24"
                            Text="10"
                            FontFamily="Consolas" FontWeight="Light" FontSize="12"
                            TextAlignment="Center" HorizontalAlignment="Right"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                            Background="{DynamicResource GrayBackgroundLight}"
                            BorderBrush="{DynamicResource BlueBorder}"
                            BorderThickness="1"
                            Margin="0,5,10,5"
                            Foreground="{DynamicResource TextColor}"
                            Style="{DynamicResource TextBoxStyle}">
                        </TextBox>
                    </Grid>
                </Border>
                <Border Grid.Row="8">
                    <Grid>
                        <TextBlock
                            FontFamily="Consolas" FontWeight="Bold" FontSize="12"
                            Text="Admin Password"
                            Margin="10,0,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource TextColor}">
                        </TextBlock>
                        <PasswordBox
                                Width="125" Height="24"
                                Password="admin"
                                FontFamily="Consolas" FontWeight="Light" FontSize="12"
                                HorizontalAlignment="Right" VerticalContentAlignment="Center"
                                Background="{DynamicResource GrayBackgroundLight}"
                                BorderBrush="{DynamicResource BlueBorder}"
                                BorderThickness="1"
                                Margin="0,5,10,5"
                                Foreground="{DynamicResource TextColor}"
                                Style="{DynamicResource PasswordBoxStyle}">
                        </PasswordBox>
                    </Grid>
                </Border>
                <Border Grid.Row="9">
                    <Grid>
                        <TextBlock
                            FontFamily="Consolas" FontWeight="Bold" FontSize="12"
                            Text="Red Password"
                            Margin="10,0,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource TextColor}">
                        </TextBlock>
                        <PasswordBox
                            Width="125" Height="24"
                            Password="red"
                            FontFamily="Consolas" FontWeight="Light" FontSize="12"
                            HorizontalAlignment="Right" VerticalContentAlignment="Center"
                            Background="{DynamicResource GrayBackgroundLight}"
                            BorderBrush="{DynamicResource BlueBorder}"
                            BorderThickness="1"
                            Margin="0,5,10,5"
                            Foreground="{DynamicResource TextColor}"
                            Style="{DynamicResource PasswordBoxStyle}">
                        </PasswordBox>
                    </Grid>
                </Border>
                <Border Grid.Row="10">
                    <Grid>
                        <TextBlock
                            FontFamily="Consolas" FontWeight="Bold" FontSize="12"
                            Text="Blue Password"
                            Margin="10,0,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource TextColor}">
                        </TextBlock>
                        <PasswordBox
                            Width="125" Height="24"
                            Password="blue"
                            FontFamily="Consolas" FontWeight="Light" FontSize="12"
                            HorizontalAlignment="Right" VerticalContentAlignment="Center"
                            Background="{DynamicResource GrayBackgroundLight}"
                            BorderBrush="{DynamicResource BlueBorder}"
                            BorderThickness="1"
                            Margin="0,5,10,5"
                            Foreground="{DynamicResource TextColor}"
                            Style="{DynamicResource PasswordBoxStyle}">
                        </PasswordBox>
                    </Grid>
                </Border>
                <Border Grid.Row="11">
                    <Grid>
                        <TextBlock
                            FontFamily="Consolas" FontWeight="Bold" FontSize="12"
                            Text="Log Level"
                            Margin="10,0,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource TextColor}">
                        </TextBlock>
                        <ComboBox
                            Width="125" Height="25"
                            Margin="0,5,10,10"
                            HorizontalAlignment="Right"
                            SelectedIndex="5"
                            Style="{StaticResource ComboBoxStyle}">
                            <ComboBoxItem>Alert</ComboBoxItem>
                            <ComboBoxItem>Error</ComboBoxItem>
                            <ComboBoxItem>Warning</ComboBoxItem>
                            <ComboBoxItem>Info</ComboBoxItem>
                            <ComboBoxItem>Debug</ComboBoxItem>
                            <ComboBoxItem>Trace</ComboBoxItem>
                        </ComboBox>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
