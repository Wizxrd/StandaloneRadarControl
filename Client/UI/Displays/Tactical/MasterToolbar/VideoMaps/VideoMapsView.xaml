<UserControl 
    x:Class="Client.UI.Displays.Tactical.MasterToolbar.VideoMaps.VideoMapsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:Client.UI.Displays.Tactical.MasterToolbar.VideoMaps"
    xmlns:toolbarButtons="clr-namespace:Client.UI.Controls.MasterToolbar"
    Height="Auto"
    x:Name="RootMapsMenu">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <toolbarButtons:MenuButton
            MenuButtonLine1="VIDEO"
            MenuButtonLine2="MAPS"
            Margin="0,1,0,0"
            Command="{Binding CommandTest}"
            DragTarget="{Binding ElementName=RootMapsMenu}"
            Grid.Row="0" Grid.Column="0"
            HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <Border Background="#252525" Grid.Column="1" BorderBrush="DarkOrange" BorderThickness="1" Visibility="{Binding BorderVisibility}" CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="2"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <toolbarButtons:ToggleButton
                        Margin="0,0,0,0"
                        ToggleButtonLine1="REGIONS"
                        IsChecked="{Binding Regions, Source={StaticResource VideoMapToggleState}, Mode=TwoWay}"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Orientation="Horizontal">
                    <toolbarButtons:ToggleButton
                        Margin="0,0,0,0"
                        ToggleButtonLine1="AIRSPACE"
                        IsChecked="{Binding Airspace, Source={StaticResource VideoMapToggleState}, Mode=TwoWay}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
