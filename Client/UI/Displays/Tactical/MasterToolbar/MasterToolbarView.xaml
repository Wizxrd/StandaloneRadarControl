<UserControl 
    x:Class="Client.UI.Displays.Tactical.MasterToolbar.MasterToolbarView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:Client.UI.Displays.Tactical.MasterToolbar"
    xmlns:adonisExtensions="clr-namespace:AdonisUI.Extensions;assembly=AdonisUI"
    xmlns:videoMapsMenu="clr-namespace:Client.UI.Displays.Tactical.MasterToolbar.VideoMaps"
    xmlns:toolbarButtons="clr-namespace:Client.UI.Controls.MasterToolbar"
    Width="Auto"
    Height="88"
    Visibility="{Binding MasterToolbarVisibility, Source={StaticResource MasterToolbarViewModel}}"
    Background="#252525"
    BorderBrush="#757575"
    BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <videoMapsMenu:VideoMapsView Grid.Row="0" Margin="2,1,0,0"/>
        <toolbarButtons:DeleteButton Grid.Row="2" Margin="2,0,0,2" Command="{Binding DeleteCommandToggle, Source={StaticResource MasterToolbarViewModel}}"/>
    </Grid>
</UserControl>
