<adonisControls:AdonisWindow 
    x:Class="Client.UI.Displays.Tactical.TacticalView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:Client.UI.Displays.Tactical"
    xmlns:adonisUi="clr-namespace:AdonisUI;assembly=AdonisUI"
    xmlns:adonisControls="clr-namespace:AdonisUI.Controls;assembly=AdonisUI"
    xmlns:adonisExtensions="clr-namespace:AdonisUI.Extensions;assembly=AdonisUI"
    xmlns:fontAwesome="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
    xmlns:masterToolbar="clr-namespace:Client.UI.Displays.Tactical.MasterToolbar"
    xmlns:toolbarControl="clr-namespace:Client.UI.Displays.Tactical.ToolbarControl"
    xmlns:commandCompositionView="clr-namespace:Client.UI.Displays.Tactical.CommandComposition"
    xmlns:displayControl="clr-namespace:Client.UI.Controls.Display"
    IconVisibility="Collapsed"
    Width="1300" Height="900"
    FontFamily="Consolas" FontSize="13"
    TitleBarBackground="#151515"
    Background="Black"
    Foreground="{StaticResource Foreground}"
    WindowButtonHighlightBrush="#303030">
    <adonisControls:AdonisWindow.InputBindings>
        <KeyBinding Key="F12" Modifiers="Ctrl" Command="{Binding OpenConnectCommand}"/>
        <KeyBinding Key="M" Modifiers="Ctrl" Command="{Binding OpenMessagesCommand}"/>
    </adonisControls:AdonisWindow.InputBindings>
    <adonisControls:AdonisWindow.TitleBarContent>
        <Menu
            Margin="-8,0,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            FontFamily="Consolas"
            FontSize="13">
            <MenuItem
                Background="#151515"
                BorderBrush="#151515"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                adonisExtensions:CursorSpotlightExtension.BackgroundBrush="#303030"
                adonisExtensions:CursorSpotlightExtension.BorderBrush="#303030"
                adonisExtensions:RippleExtension.BackgroundBrush="{StaticResource Blue}">
                <MenuItem.Header>
                    <Image
                        Source="/Resources/Images/Menu.png"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="15" Height="26"/>
                </MenuItem.Header>
                <MenuItem
                    Header="Connect"
                    InputGestureText="Ctrl+F12"
                    Background="#151515"
                    BorderBrush="#151515"
                    adonisExtensions:CursorSpotlightExtension.BackgroundBrush="#303030"
                    adonisExtensions:CursorSpotlightExtension.BorderBrush="#303030"
                    adonisExtensions:RippleExtension.BackgroundBrush="{StaticResource Blue}"
                    Command="{Binding OpenConnectCommand}"/>
                <MenuItem
                    Header="Views"
                    Background="#151515"
                    BorderBrush="#151515"
                    adonisExtensions:CursorSpotlightExtension.BackgroundBrush="#303030"
                    adonisExtensions:CursorSpotlightExtension.BorderBrush="#303030"
                    adonisExtensions:RippleExtension.BackgroundBrush="{StaticResource Blue}"
                    Command="{Binding OpenConnectCommand}">
                    <MenuItem
                        Header="Messages"
                        InputGestureText="Ctrl+M"
                        Background="#151515"
                        BorderBrush="#151515"
                        adonisExtensions:CursorSpotlightExtension.BackgroundBrush="#303030"
                        adonisExtensions:CursorSpotlightExtension.BorderBrush="#303030"
                        adonisExtensions:RippleExtension.BackgroundBrush="{StaticResource Blue}"
                        Command="{Binding OpenMessagesCommand}"/>
                </MenuItem>
            </MenuItem>
        </Menu>
    </adonisControls:AdonisWindow.TitleBarContent>
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0" CornerRadius="0" CaptionHeight="0"/>
    </WindowChrome.WindowChrome>
    <Border>
        <Grid x:Name="RootGrid">
            <displayControl:RenderView x:Name="RenderView"/>
            <masterToolbar:MasterToolbarView HorizontalAlignment="Stretch" VerticalAlignment="Top" Panel.ZIndex="{Binding ZIndex, Source={StaticResource MasterToolbarViewModel}}"/>
            <commandCompositionView:CommandCompositionView
                x:Name="CommandComposition"
                Panel.ZIndex="{Binding ZIndex, Source={StaticResource CommandCompositionViewModel}}"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
            <toolbarControl:ToolbarControlView Margin="0,450,0,0" Width="Auto" Height="Auto"/>
            <TextBlock
                Text="{Binding DisplayStatus, UpdateSourceTrigger=PropertyChanged}"
                Foreground="Red"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                FontFamily="/Resources/Fonts/Retro.ttf#Retro Regular" FontSize="18"/>
        </Grid>
    </Border>
</adonisControls:AdonisWindow>
