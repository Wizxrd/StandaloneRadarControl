<UserControl 
    x:Class="Client.UI.Displays.Tactical.ToolbarControl.ToolbarControlView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:Client.UI.Displays.Tactical.ToolbarControl"
    xmlns:adonisExtensions="clr-namespace:AdonisUI.Extensions;assembly=AdonisUI"
    xmlns:videoMapsMenu="clr-namespace:Client.UI.Displays.Tactical.MasterToolbar.VideoMaps"
    xmlns:toolbarButtons="clr-namespace:Client.UI.Controls.MasterToolbar"
    Width="Auto"
    Height="Auto"
    x:Name="RootMapsMenu">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <toolbarButtons:MenuButton
            MenuButtonLine1="TOOLBAR"
            Margin="0,0,0,0"
            Command="{Binding CommandTest}"
            DragTarget="{Binding ElementName=RootMapsMenu}"
            Grid.Row="0" Grid.Column="0"
            HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <Border Background="#252525" Grid.Column="1" BorderBrush="DarkOrange" BorderThickness="1" Visibility="{Binding BorderVisibility}" CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="2"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <toolbarButtons:ToggleButton
                        Margin="0,0,0,0"
                        CloneGroup="MASTER_TOOLBAR"
                        ToggleButtonLine1="MASTER"
                        ToggleButtonLine2="TOOLBAR"
                        Command="{Binding MasterToolbarCommand, Source={StaticResource MasterToolbarViewModel}}"
                        IsChecked="{Binding MasterToolbar, Source={StaticResource ToolbarControlToggleState}, Mode=TwoWay}"/>

                    <toolbarButtons:ToggleButton
                        Margin="0,0,0,0"
                        CloneGroup="CCA_TOOLBAR"
                        ToggleButtonLine1="CCA"
                        ToggleButtonLine2="TOOLBAR"
                        Command="{Binding CommandCompositionAreaCommand, Source={StaticResource CommandCompositionViewModel}}"
                        IsChecked="{Binding CommandCompositionArea, Source={StaticResource ToolbarControlToggleState}, Mode=TwoWay}"/>

                </StackPanel>

                <StackPanel Grid.Row="2" Orientation="Horizontal">
                    <toolbarButtons:ToggleButton
                        Margin="0,0,0,0"
                        CloneGroup="MASTER_RAISELOWER"
                        ToggleButtonLine1="MASTER"
                        ToggleButtonLine2="{Binding RaiseLowerText, Source={StaticResource MasterToolbarViewModel}}"
                        Command="{Binding MasterRaiseLowerCommand, Source={StaticResource MasterToolbarViewModel}}"
                        IsChecked="{Binding MasterRaise, Source={StaticResource ToolbarControlToggleState}, Mode=TwoWay}"/>

                    <toolbarButtons:ToggleButton
                        Margin="0,0,0,0"
                        CloneGroup="CCA_RAISELOWER"
                        ToggleButtonLine1="CCA"
                        ToggleButtonLine2="{Binding RaiseLowerText, Source={StaticResource CommandCompositionViewModel}}"
                        Command="{Binding CommandCompositionAreaRaiseLowerCommand, Source={StaticResource CommandCompositionViewModel}}"
                        IsChecked="{Binding CommandCompositionAreaRaise, Source={StaticResource ToolbarControlToggleState}, Mode=TwoWay}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
