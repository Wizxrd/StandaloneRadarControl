<UserControl 
    x:Class="Client.UI.Displays.Tactical.CommandComposition.CommandCompositionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:Client.UI.Displays.Tactical.CommandComposition"
    Width="400"
    MinHeight="110"
    Background="Black"
    FontFamily="/Resources/Fonts/Retro.ttf#Retro Regular"
    FontSize="16"
    BorderBrush="{StaticResource FieldBorderBrush}"
    BorderThickness="1"
    Visibility="{Binding CommandCompositionVisibility}"
    DataContext="{StaticResource CommandCompositionViewModel}">
    <Border>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    BorderBrush="{StaticResource FieldBorderBrush}"
                    BorderThickness="0,0,0,1">
                <TextBlock
                    x:Name="CompositionTextBlock"
                    Margin="5"
                    Text="_"
                    TextWrapping="Wrap"
                    Foreground="White"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top"/>
            </Border>

            <Border Grid.Row="1"
                    BorderBrush="{StaticResource FieldBorderBrush}"/>

            <TextBlock
                Grid.Row="2"
                Name="AcceptedTextBox"
                Margin="5,5,0,0"
                TextWrapping="Wrap"
                Foreground="LimeGreen"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"/>

            <TextBlock
                Grid.Row="2"
                Name="InvalidTextBox"
                Margin="8,11,0,0"
                FontSize="10"
                TextWrapping="Wrap"
                Foreground="Red"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"/>

            <TextBlock
                Grid.Row="2"
                x:Name="FeedbackTextBlock"
                Margin="20,5,0,0"
                TextWrapping="Wrap"
                Foreground="White"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"/>
        </Grid>
    </Border>
</UserControl>
