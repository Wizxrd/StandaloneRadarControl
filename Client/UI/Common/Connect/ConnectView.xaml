<adonisControls:AdonisWindow 
    x:Class="Client.UI.Common.Connect.ConnectView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:Client.UI.Common.Connect"
    xmlns:adonisUi="clr-namespace:AdonisUI;assembly=AdonisUI"
    xmlns:adonisControls="clr-namespace:AdonisUI.Controls;assembly=AdonisUI"
    xmlns:adonisExtensions="clr-namespace:AdonisUI.Extensions;assembly=AdonisUI"
    SizeToContent="Width" Height="300"
    ResizeMode="NoResize"
    FontFamily="Consolas" FontSize="13"
    Title="Connect"
    TitleBarBackground="{StaticResource PanelBackground}"
    Background="{StaticResource BackgroundBrush}"
    Foreground="{StaticResource Foreground}"
    BorderBrush="{StaticResource BorderBrush}"
    WindowButtonHighlightBrush="{StaticResource BorderBrush}"
    BorderThickness="1">
    <Border Background="{StaticResource BackgroundBrush}" BorderBrush="#2C3136" BorderThickness="0,1,0,0" Padding="10">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition MinWidth="300" Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border
                Grid.Row="2" Grid.Column="0"
                CornerRadius="3"
                Background="{StaticResource PanelBackground}"
                BorderBrush="{StaticResource PanelBorder}" BorderThickness="1"
                Padding="10" HorizontalAlignment="Left" Width="97">
                <StackPanel>
                    <Button
                        IsEnabled="{Binding NewBookmarkEnabled}"
                        Width="75" Height="26"
                        Margin="0,0,0,0"
                        Background="{StaticResource BackgroundBrush}"
                        BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.AccentBrush}}"
                        adonisExtensions:CornerRadiusExtension.CornerRadius="3"
                        adonisExtensions:CursorSpotlightExtension.BackgroundBrush="{StaticResource FieldBrush}"
                        adonisExtensions:RippleExtension.BackgroundBrush="{StaticResource Blue}"
                        Content="New"
                        Command="{Binding NewBookmarkCommand}"/>
                    <Button
                        Margin="0,5,0,0"
                        Width="75" Height="26"
                        Background="{StaticResource BackgroundBrush}"
                        BorderBrush="{StaticResource FieldBorderBrush}"
                        adonisExtensions:CornerRadiusExtension.CornerRadius="3"
                        adonisExtensions:CursorSpotlightExtension.BackgroundBrush="{StaticResource FieldBrush}"
                        adonisExtensions:RippleExtension.BackgroundBrush="{StaticResource Blue}"
                        Content="Rename"
                        IsEnabled="{Binding IsBookmarkSelected}"
                        Command="{Binding RenameBookmarkCommand}"/>
                    <Button
                        Margin="0,5,0,0"
                        Width="75" Height="26"
                        Background="{StaticResource BackgroundBrush}"
                        BorderBrush="{StaticResource FieldBorderBrush}"
                        adonisExtensions:CornerRadiusExtension.CornerRadius="3"
                        adonisExtensions:CursorSpotlightExtension.BackgroundBrush="{StaticResource FieldBrush}"
                        adonisExtensions:RippleExtension.BackgroundBrush="{StaticResource Blue}"
                        Content="Copy"
                        IsEnabled="{Binding IsBookmarkSelected}"
                        Command="{Binding CopyBookmarkCommand}"/>
                    <Button
                        Margin="0,5,0,0"
                        Width="75" Height="26"
                        Background="{StaticResource BackgroundBrush}"
                        BorderBrush="{StaticResource FieldBorderBrush}"
                        adonisExtensions:CornerRadiusExtension.CornerRadius="3"
                        adonisExtensions:CursorSpotlightExtension.BackgroundBrush="{StaticResource FieldBrush}"
                        adonisExtensions:RippleExtension.BackgroundBrush="{StaticResource Blue}"
                        Content="Delete"
                        IsEnabled="{Binding IsBookmarkSelected}"
                        Command="{Binding DeleteBookmarkCommand}"/>
                    <Border BorderBrush="{StaticResource FieldBorderBrush}" BorderThickness="0,1,0,0" Margin="0,5,0,0"/>
                    <Button
                        IsEnabled="{Binding SaveBookmarkEnabled}"
                        Margin="0,5,0,0"
                        Width="75" Height="26"
                        Background="{StaticResource BackgroundBrush}"
                        BorderBrush="{StaticResource FieldBorderBrush}"
                        adonisExtensions:CornerRadiusExtension.CornerRadius="3"
                        adonisExtensions:CursorSpotlightExtension.BackgroundBrush="{StaticResource FieldBrush}"
                        adonisExtensions:RippleExtension.BackgroundBrush="{StaticResource Blue}"
                        Content="Save"
                        Command="{Binding SaveBookmarkCommand}"/>
                </StackPanel>
            </Border>
            <Border 
                Grid.ColumnSpan="3"
                CornerRadius="3"
                Background="{StaticResource PanelBackground}"
                BorderBrush="{StaticResource PanelBorder}" BorderThickness="1"
                Padding="10">
                <TextBox
                    Background="{StaticResource BackgroundBrush}"
                    Foreground="#F5F5F5"
                    BorderBrush="{StaticResource FieldBorderBrush}"
                    BorderThickness="1"
                    Padding="5"
                    HorizontalContentAlignment="Left"
                    VerticalContentAlignment="Center"
                    adonisExtensions:CornerRadiusExtension.CornerRadius="3"
                    adonisExtensions:CursorSpotlightExtension.BackgroundBrush="{StaticResource FieldBrush}"
                    adonisExtensions:WatermarkExtension.Watermark="Search..."
                    Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"/>
            </Border>
            <Border
                Grid.Row="2" Grid.Column="2"
                CornerRadius="3"
                Background="{StaticResource PanelBackground}"
                BorderBrush="{StaticResource PanelBorder}" BorderThickness="1"
                Padding="10">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding FilteredBookmarks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ToggleButton
                                    Tag="{Binding}"
                                    IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                    Height="32"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Command="{Binding DataContext.SelectBookmarkCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource BookmarkToggleButton}">
                                    <ToggleButton.Content>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <ContentControl Grid.Column="0" Content="{Binding}" Style="{DynamicResource RenameButtonControl}"/>
                                        </Grid>
                                    </ToggleButton.Content>
                                </ToggleButton>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
            <Border
                Grid.Column="4"
                Grid.RowSpan="3"
                CornerRadius="3"
                Background="{StaticResource PanelBackground}"
                BorderBrush="{StaticResource PanelBorder}" BorderThickness="1"
                Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" VerticalAlignment="Center">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock
                                    Margin="0,0,0,5"
                                    FontWeight="Bold"
                                    Text="Address"
                                    Foreground="{StaticResource White}"/>
                                <TextBox
                                    Background="{StaticResource BackgroundBrush}"
                                    Foreground="#F5F5F5"
                                    BorderBrush="{StaticResource FieldBorderBrush}"
                                    BorderThickness="1"
                                    Padding="5"
                                    HorizontalContentAlignment="Left"
                                    VerticalContentAlignment="Center"
                                    adonisExtensions:CornerRadiusExtension.CornerRadius="3"
                                    adonisExtensions:CursorSpotlightExtension.BackgroundBrush="{StaticResource FieldBrush}"
                                    Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                <TextBlock
                                    Margin="0,0,0,5"
                                    FontWeight="Bold"
                                    Text="Port"
                                    Foreground="{StaticResource White}"/>
                                <TextBox
                                    Background="{StaticResource BackgroundBrush}"
                                    Foreground="#F5F5F5"
                                    BorderBrush="{StaticResource FieldBorderBrush}"
                                    BorderThickness="1"
                                    Padding="5"
                                    HorizontalContentAlignment="Left"
                                    VerticalContentAlignment="Center"
                                    adonisExtensions:CornerRadiusExtension.CornerRadius="3"
                                    adonisExtensions:CursorSpotlightExtension.BackgroundBrush="{StaticResource FieldBrush}"
                                    Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock
                            Margin="0,5,0,5"
                            FontWeight="Bold"
                            Text="Password"
                            Foreground="{StaticResource White}"/>
                        <TextBox
                            Background="{StaticResource BackgroundBrush}"
                            Foreground="#F5F5F5"
                            BorderBrush="{StaticResource FieldBorderBrush}"
                            BorderThickness="1"
                            Padding="5"
                            HorizontalContentAlignment="Left"
                            VerticalContentAlignment="Center"
                            adonisExtensions:CornerRadiusExtension.CornerRadius="3"
                            adonisExtensions:CursorSpotlightExtension.BackgroundBrush="{StaticResource FieldBrush}"
                            Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock
                            Margin="0,5,0,5"
                            FontWeight="Bold"
                            Text="Callsign"
                            Foreground="{StaticResource White}"/>
                        <TextBox
                            Background="{StaticResource BackgroundBrush}"
                            Foreground="#F5F5F5"
                            BorderBrush="{StaticResource FieldBorderBrush}"
                            BorderThickness="1"
                            Padding="5"
                            HorizontalContentAlignment="Left"
                            VerticalContentAlignment="Center"
                            adonisExtensions:CornerRadiusExtension.CornerRadius="3"
                            adonisExtensions:CursorSpotlightExtension.BackgroundBrush="{StaticResource FieldBrush}"
                            Text="{Binding Callsign, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button
                            IsEnabled="{Binding ConnectEnabled}"
                            Width="100" Height="26"
                            Margin="5,0,5,0"
                            Background="{StaticResource BackgroundBrush}"
                            BorderBrush="{DynamicResource {x:Static adonisUi:Brushes.AccentBrush}}"
                            adonisExtensions:CornerRadiusExtension.CornerRadius="3"
                            adonisExtensions:CursorSpotlightExtension.BackgroundBrush="{StaticResource FieldBrush}"
                            adonisExtensions:RippleExtension.BackgroundBrush="{StaticResource Blue}"
                            Content="Connect"
                            Command="{Binding ConnectCommand}"/>
                        <Button
                            Margin="0,0,0,0"
                            Width="75" Height="26"
                            Background="{StaticResource BackgroundBrush}"
                            BorderBrush="{StaticResource FieldBorderBrush}"
                            adonisExtensions:CornerRadiusExtension.CornerRadius="3"
                            adonisExtensions:CursorSpotlightExtension.BackgroundBrush="{StaticResource FieldBrush}"
                            adonisExtensions:RippleExtension.BackgroundBrush="{StaticResource Blue}"
                            Content="Cancel"
                            Command="{Binding CancelCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</adonisControls:AdonisWindow>
