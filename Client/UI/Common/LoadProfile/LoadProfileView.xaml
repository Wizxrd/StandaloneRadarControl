<adonisControls:AdonisWindow 
    x:Class="Client.UI.Common.LoadProfile.LoadProfileView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:Client.UI.Common.LoadProfile"
    xmlns:adonisUi="clr-namespace:AdonisUI;assembly=AdonisUI"
    xmlns:adonisControls="clr-namespace:AdonisUI.Controls;assembly=AdonisUI"
    xmlns:adonisExtensions="clr-namespace:AdonisUI.Extensions;assembly=AdonisUI"
    Title="Load Profile"
    MinWidth="440" Width="440" Height="500"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    FontFamily="Consolas" FontSize="13"
    TitleBarBackground="{StaticResource PanelBackground}"
    Background="{StaticResource BackgroundBrush}"
    Foreground="{StaticResource Foreground}"
    BorderBrush="{StaticResource BorderBrush}"
    WindowButtonHighlightBrush="{StaticResource BorderBrush}"
    BorderThickness="1">
    <adonisControls:AdonisWindow.InputBindings>
        <KeyBinding Key="Esc" Command="{Binding StopRenamingCommand}"/>
        <KeyBinding Key="Enter" Command="{Binding StopRenamingCommand}"/>
    </adonisControls:AdonisWindow.InputBindings>
    <Border Background="{StaticResource BackgroundBrush}" BorderBrush="#2C3136" BorderThickness="0,1,0,0" Padding="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="100"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
            </Grid.ColumnDefinitions>
            <Border 
                Grid.Row="0" Grid.ColumnSpan="3"
                CornerRadius="3"
                Background="{StaticResource PanelBackground}"
                BorderBrush="{StaticResource PanelBorder}" BorderThickness="1"
                Padding="10">
                <TextBox
                    Background="{StaticResource BackgroundBrush}"
                    Foreground="#F5F5F5"
                    BorderBrush="{StaticResource FieldBorderBrush}"
                    BorderThickness="1"
                    Padding="5"
                    HorizontalContentAlignment="Left"
                    VerticalContentAlignment="Center"
                    adonisExtensions:CornerRadiusExtension.CornerRadius="3"
                    adonisExtensions:CursorSpotlightExtension.BackgroundBrush="{StaticResource FieldBrush}"
                    adonisExtensions:WatermarkExtension.Watermark="Search..."
                    Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"/>
            </Border>
            <Border 
                Grid.Row="2" Grid.Column="2"
                CornerRadius="3"
                Background="{StaticResource PanelBackground}"
                BorderBrush="{StaticResource PanelBorder}" BorderThickness="1"
                Padding="10">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding FilteredProfiles}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ToggleButton
                                    Tag="{Binding}"
                                    IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                    Height="32"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Command="{Binding DataContext.SelectProfileCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource ProfileToggleButton}">
                                    <ToggleButton.Content>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <ContentControl Grid.Column="0" Content="{Binding}" Style="{DynamicResource RenameButtonControl}"/>
                                        </Grid>
                                    </ToggleButton.Content>
                                </ToggleButton>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
            <Border 
                Grid.Row="2" Grid.Column="0"
                CornerRadius="3"
                Background="{StaticResource PanelBackground}"
                BorderBrush="{StaticResource PanelBorder}" BorderThickness="1"
                Padding="10">
                <StackPanel>
                    <Button
                        Margin="0,0,0,5"
                        Height="24"
                        Background="{StaticResource BackgroundBrush}"
                        BorderBrush="{StaticResource FieldBorderBrush}"
                        adonisExtensions:CornerRadiusExtension.CornerRadius="3"
                        adonisExtensions:CursorSpotlightExtension.BackgroundBrush="{StaticResource FieldBrush}"
                        adonisExtensions:RippleExtension.BackgroundBrush="{StaticResource Blue}"
                        Content="New"
                        Command="{Binding NewProfileCommand}"/>
                    <Button
                        Margin="0,0,0,0"
                        Height="24"
                        Background="{StaticResource BackgroundBrush}"
                        BorderBrush="{StaticResource FieldBorderBrush}"
                        adonisExtensions:CornerRadiusExtension.CornerRadius="3"
                        adonisExtensions:CursorSpotlightExtension.BackgroundBrush="{StaticResource FieldBrush}"
                        adonisExtensions:RippleExtension.BackgroundBrush="{StaticResource Blue}"
                        Content="Import"
                        Command="{Binding ImportProfileCommand}"/>
                    <Border BorderBrush="{StaticResource PanelBorder}" BorderThickness="0,1,0,0" Margin="0,5,0,5"/>
                    <Button
                        Margin="0,0,0,5"
                        Height="24"
                        Background="{StaticResource BackgroundBrush}"
                        BorderBrush="{StaticResource FieldBorderBrush}"
                        adonisExtensions:CornerRadiusExtension.CornerRadius="3"
                        adonisExtensions:CursorSpotlightExtension.BackgroundBrush="{StaticResource FieldBrush}"
                        adonisExtensions:RippleExtension.BackgroundBrush="{StaticResource Blue}"
                        Content="Load"
                        IsEnabled="{Binding IsProfileSelected}"
                        Command="{Binding LoadProfileCommand}"/>
                    <Button
                        Margin="0,0,0,5"
                        Height="24"
                        Background="{StaticResource BackgroundBrush}"
                        BorderBrush="{StaticResource FieldBorderBrush}"
                        adonisExtensions:CornerRadiusExtension.CornerRadius="3"
                        adonisExtensions:CursorSpotlightExtension.BackgroundBrush="{StaticResource FieldBrush}"
                        adonisExtensions:RippleExtension.BackgroundBrush="{StaticResource Blue}"
                        Content="Rename"                        
                        IsEnabled="{Binding IsProfileSelected}"
                        Command="{Binding DataContext.RenameProfileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="{Binding}"/>
                    <Button
                        Margin="0,0,0,5"
                        Height="24"
                        Background="{StaticResource BackgroundBrush}"
                        BorderBrush="{StaticResource FieldBorderBrush}"
                        adonisExtensions:CornerRadiusExtension.CornerRadius="3"
                        adonisExtensions:CursorSpotlightExtension.BackgroundBrush="{StaticResource FieldBrush}"
                        adonisExtensions:RippleExtension.BackgroundBrush="{StaticResource Blue}"
                        Content="Copy"
                        IsEnabled="{Binding IsProfileSelected}"
                        Command="{Binding CopyProfileCommand}"/>
                    <Button
                        Margin="0,0,0,5"
                        Height="24"
                        Background="{StaticResource BackgroundBrush}"
                        BorderBrush="{StaticResource FieldBorderBrush}"
                        adonisExtensions:CornerRadiusExtension.CornerRadius="3"
                        adonisExtensions:CursorSpotlightExtension.BackgroundBrush="{StaticResource FieldBrush}"
                        adonisExtensions:RippleExtension.BackgroundBrush="{StaticResource Blue}"
                        Content="Export"
                        IsEnabled="{Binding IsProfileSelected}"
                        Command="{Binding ExportProfileCommand}"/>
                    <Button
                        Margin="0,0,0,5"
                        Height="24"
                        Background="{StaticResource BackgroundBrush}"
                        BorderBrush="{StaticResource FieldBorderBrush}"
                        adonisExtensions:CornerRadiusExtension.CornerRadius="3"
                        adonisExtensions:CursorSpotlightExtension.BackgroundBrush="{StaticResource FieldBrush}"
                        adonisExtensions:RippleExtension.BackgroundBrush="{StaticResource Blue}"
                        Content="Delete"
                        IsEnabled="{Binding IsProfileSelected}"
                        Command="{Binding DeleteProfileCommand}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</adonisControls:AdonisWindow>
