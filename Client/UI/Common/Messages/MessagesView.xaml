<adonisControls:AdonisWindow
    x:Class="Client.UI.Common.Messages.MessagesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:Client.UI.Common.Messages"
    xmlns:adonisControls="clr-namespace:AdonisUI.Controls;assembly=AdonisUI"
    xmlns:adonisExtensions="clr-namespace:AdonisUI.Extensions;assembly=AdonisUI"
    mc:Ignorable="d"
    Title="Messages"
    IconVisibility="Collapsed"
    Background="Black"
    WindowStyle="ToolWindow"
    TitleBarBackground="#151515"
    Width="600" Height="300"
    BorderBrush="{StaticResource FieldBorderBrush}" BorderThickness="1"
    FontFamily="Consolas" FontSize="13"
    FocusManager.FocusedElement="{Binding ElementName=MessageTextBox}">
    <adonisControls:AdonisWindow.InputBindings>
        <KeyBinding Key="Enter" Command="{Binding SendMessageCommand}" />
        <KeyBinding Key="M" Modifiers="Ctrl" Command="{Binding CloseMessagesCommand}" />
        <KeyBinding Key="F12" Modifiers="Ctrl" Command="{Binding OpenConnectCommand}" />
    </adonisControls:AdonisWindow.InputBindings>
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0"
                      CornerRadius="0"
                      CaptionHeight="0" />
    </WindowChrome.WindowChrome>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Border>
            <StackPanel Orientation="Horizontal">
                <ToggleButton
                    Width="50"
                    Height="24"
                    Margin="0"
                    BorderThickness="0,1,1,0"
                    Content="ALL"
                    IsChecked="{Binding IsAllSelected}">
                    <ToggleButton.Style>
                        <Style TargetType="ToggleButton"
                               BasedOn="{StaticResource DefaultMessageTab}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasUnreadAll}"
                                             Value="True">
                                    <Setter Property="Foreground" Value="Red" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ToggleButton.Style>
                </ToggleButton>
                <ToggleButton
                    Width="50"
                    Height="24"
                    Margin="0"
                    BorderThickness="0,1,1,0"
                    Content="ALLIES"
                    IsChecked="{Binding IsAlliesSelected}">
                    <ToggleButton.Style>
                        <Style TargetType="ToggleButton"
                               BasedOn="{StaticResource DefaultMessageTab}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasUnreadAllies}"
                                             Value="True">
                                    <Setter Property="Foreground" Value="Red" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ToggleButton.Style>
                </ToggleButton>
            </StackPanel>
        </Border>
        <Border
            Grid.Row="1"
            BorderBrush="{StaticResource FieldBorderBrush}"
            BorderThickness="0,1,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding FilteredMessages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock
                                Margin="4,2"
                                Text="{Binding DisplayText}"
                                Foreground="{Binding Foreground}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
        <Border
            Grid.Row="2"
            BorderBrush="{StaticResource FieldBorderBrush}"
            BorderThickness="0,1,0,0">
            <TextBox
                x:Name="MessageTextBox"
                Background="Black"
                Foreground="#F5F5F5"
                BorderThickness="0"
                Padding="5"
                HorizontalContentAlignment="Left"
                VerticalContentAlignment="Center"
                adonisExtensions:CursorSpotlightExtension.BackgroundBrush="Black"
                Text="{Binding MessageText, UpdateSourceTrigger=PropertyChanged}" />
        </Border>
    </Grid>
</adonisControls:AdonisWindow>
