<UserControl 
    x:Class="Client.UI.Controls.MasterToolbar.DeleteButton"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    FontFamily="/Resources/Fonts/Retro.ttf#Retro Regular"
    FontSize="12">
    <StackPanel Orientation="Horizontal">
        <Button x:Name="DragHandle" Width="15" Style="{StaticResource TearoffButton}"/>
        <ToggleButton 
            Style="{StaticResource DeleteButton}" Width="90" Height="40"
            Command="{Binding Command, RelativeSource={RelativeSource AncestorType=UserControl}}"
            IsChecked="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}">
            <TextBlock TextAlignment="Center">
                <Run Text="DELETE"/>
                <LineBreak/>
                <Run Text="TEAROFF"/>
            </TextBlock>
        </ToggleButton>
    </StackPanel>
</UserControl>
