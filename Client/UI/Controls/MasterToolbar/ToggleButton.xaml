<UserControl 
    x:Class="Client.UI.Controls.MasterToolbar.ToggleButton"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    FontFamily="/Resources/Fonts/Retro.ttf#Retro Regular"
    FontSize="12">
    <StackPanel Orientation="Horizontal">
        <Button x:Name="DragHandle" Width="15" Style="{StaticResource TearoffButton}"/>
        <ToggleButton
            IsChecked="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=UserControl}}"
            Style="{StaticResource ToggleButton}" Width="90" Height="40"
            Command="{Binding Command, RelativeSource={RelativeSource AncestorType=UserControl}}">
            <TextBlock TextAlignment="Center">
                <Run Text="{Binding ToggleButtonLine1, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                <LineBreak/>
                <Run Text="{Binding ToggleButtonLine2, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            </TextBlock>
        </ToggleButton>
    </StackPanel>
</UserControl>