<UserControl 
    x:Class="Client.UI.Controls.MasterToolbar.MenuButton"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:Client.UI.Displays.Tactical"
    FontFamily="/Resources/Fonts/Retro.ttf#Retro Regular"
    FontSize="12">
    <StackPanel Orientation="Horizontal">
        <Button x:Name="DragHandle" Width="15" Style="{StaticResource TearoffButton}"/>
        <ToggleButton
            Style="{StaticResource MenuButton}" Width="90" Height="40"
            Command="{Binding Command, RelativeSource={RelativeSource AncestorType=UserControl}}">
            <TextBlock TextAlignment="Center">
                <Run Text="{Binding MenuButtonLine1, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                <LineBreak/>
                <Run Text="{Binding MenuButtonLine2, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            </TextBlock>
        </ToggleButton>
    </StackPanel>
</UserControl>
