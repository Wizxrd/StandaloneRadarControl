<Window x:Class="Client.Views.GeneralSettingsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Client.Views"
        mc:Ignorable="d"
        Width="300" Height="400"
        Cursor="Arrow"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0" CornerRadius="0" CaptionHeight="0"/>
    </WindowChrome.WindowChrome>
    <Border Background="{DynamicResource GrayBackground}" BorderBrush="{DynamicResource GrayBorder}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Height="30" BorderBrush="{DynamicResource GrayBorder}" BorderThickness="0,0,0,1" MouseDown="BorderMouseDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0" Width="20" Height="20" Source="pack://application:,,,/Images/Settings.png" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="5,0,0,0"/>
                    <TextBlock Text="General Settings" Grid.Column="1" Foreground="{DynamicResource TextColor}" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" Margin="5,0,0,0"/>
                    <Button
                        x:Name="GeneralSettingsCloseButton"
                        ToolTip="Close"
                        Grid.Column="4"
                        Width="45"
                        Style="{StaticResource CloseButtonStyle}"
                        Tag="pack://application:,,,/Images/Close.png"
                        Click="CloseButtonClick">
                    </Button>
                </Grid>
            </Border>
            <Border Grid.Row="1" Margin="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock
                        Text="Log Level:"
                        Grid.Row="0"
                        HorizontalAlignment="Center"
                        Margin="80,0,0,1"
                        Foreground="{DynamicResource TextColor}">
                    </TextBlock>
                    <ComboBox
                        Name="DebugLevelComboBox"
                        SelectedIndex="4"
                        Grid.Row="1"
                        Width="125" Height="24"
                        HorizontalAlignment="Right"
                        Margin="0,0,0,10"
                        Style="{StaticResource ComboBoxStyle}">
                        <ComboBoxItem Content="Alert"/>
                        <ComboBoxItem Content="Error"/>
                        <ComboBoxItem Content="Warning"/>
                        <ComboBoxItem Content="Info"/>
                        <ComboBoxItem Content="Debug"/>
                        <ComboBoxItem Content="Trace"/>
                    </ComboBox>
                    <TextBlock
                    Text="Cursor:"
                    Grid.Row="0"
                    Margin="0,0,0,1"
                    Foreground="{DynamicResource TextColor}">
                    </TextBlock>
                    <ComboBox
                        Name="CursorComboBox"
                        SelectedIndex="0"
                        Grid.Row="1"
                        Width="125" Height="24"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,5"
                        Style="{StaticResource ComboBoxStyle}">
                        <ComboBoxItem Content="Cross1"/>
                        <ComboBoxItem Content="Cross2"/>
                        <ComboBoxItem Content="Cross3"/>
                        <ComboBoxItem Content="Scope1"/>
                        <ComboBoxItem Content="Scope2"/>
                        <ComboBoxItem Content="Scope3"/>
                    </ComboBox>
                    <TextBlock
                        Text="Display Units:"
                        Grid.Row="2"
                        Margin="0,0,0,1"
                        Foreground="{DynamicResource TextColor}">
                    </TextBlock>
                    <ComboBox
                        Name="DisplayUnitsComboBox"
                        SelectedIndex="0"
                        Grid.Row="3"
                        Width="125" Height="24"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,10"
                        Style="{StaticResource ComboBoxStyle}">
                        <ComboBoxItem Content="Imperial"/>
                        <ComboBoxItem Content="Metric"/>
                    </ComboBox>
                    <CheckBox
                        IsChecked="True"
                        Grid.Row="4"
                        Content="Disconnect prompt"
                        Margin="0,0,0,5"
                        Style="{DynamicResource CheckBoxStyle}">
                    </CheckBox>
                    <CheckBox
                        IsChecked="True"
                        Grid.Row="5"
                        Content="Disconnect prompt while connected"
                        Margin="0,0,0,5"
                        Style="{DynamicResource CheckBoxStyle}">
                    </CheckBox>
                    <CheckBox
                        IsChecked="True"
                        Grid.Row="6"
                        Content="Play handoff sounds"
                        Margin="0,0,0,5"
                        Style="{DynamicResource CheckBoxStyle}">
                    </CheckBox>
                    <CheckBox
                        IsChecked="True"
                        Grid.Row="7"
                        Content="Play chat sounds"
                        Margin="0,0,0,5"
                        Style="{DynamicResource CheckBoxStyle}">
                    </CheckBox>
                    <CheckBox
                        Grid.Row="8"
                        Content="Discord presence"
                        Margin="0,0,0,5"
                        Style="{DynamicResource CheckBoxStyle}">
                    </CheckBox>
                    <CheckBox
                        IsChecked="True"
                        Grid.Row="9"
                        Content="Remember last connection"
                        Margin="0,0,0,5"
                        Style="{DynamicResource CheckBoxStyle}">
                    </CheckBox>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
