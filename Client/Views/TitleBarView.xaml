<UserControl x:Class="Client.Views.TitleBarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Client.Views"
             mc:Ignorable="d"
             Cursor="Arrow"
             Width="1280" Height="25">
    <Border x:Name="TitleBorder" Background="{DynamicResource TitleBarColor}" MouseDown="TitleBarMouseDown">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button
                x:Name="MenuButton"
                ToolTip="Menu"
                Grid.Column="0"
                Width="37"
                Style="{DynamicResource WindowsButtonStyle}"
                Tag="pack://application:,,,/Images/Menu.png"
                Click="MenuButtonClick">
            </Button>
            <TextBlock
                x:Name="TitleBarTextBlock"
                Text="SRC"
                Grid.Column="1"
                Foreground="{DynamicResource TextColor}"
                FontFamily="Consolas" FontWeight="Light" FontSize="12"
                VerticalAlignment="Center"
                Margin="10,0,0,0">
            </TextBlock>
            <Button
                x:Name="MinimizeButton"
                ToolTip="Minimize"
                Grid.Column="2"
                Width="37"
                Style="{DynamicResource WindowsButtonStyle}"
                Tag="pack://application:,,,/Images/Minimize.png"
                Click="MinimizeButtonClick">
            </Button>
            <Button
                x:Name="MaximizeButton"
                ToolTip="Maximize"
                Grid.Column="3"
                Width="37"
                Style="{DynamicResource WindowsButtonStyle}"
                Tag="pack://application:,,,/Images/Maximize.png"
                Click="MaximizeButtonClick">
            </Button>
            <Button
                x:Name="CloseButton"
                ToolTip="Close"
                Grid.Column="4"
                Width="37"
                Style="{DynamicResource CloseButtonStyle}"
                Tag="pack://application:,,,/Images/Close.png"
                Click="CloseButtonClick">
            </Button>
        </Grid>
    </Border>
</UserControl>
