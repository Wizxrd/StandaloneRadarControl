<Window x:Class="Client.Views.DisplaySettingsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Width="300" Height="400"
        Cursor="Arrow"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
	<WindowChrome.WindowChrome>
		<WindowChrome GlassFrameThickness="0" CornerRadius="0" CaptionHeight="0" />
	</WindowChrome.WindowChrome>
	<Border Background="{DynamicResource GrayBackground}" BorderBrush="{DynamicResource GrayBorder}" BorderThickness="1">
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="*" />
			</Grid.RowDefinitions>
			<Border Grid.Row="0" Height="30" BorderBrush="{DynamicResource GrayBorder}" BorderThickness="0,0,0,1"
			        MouseDown="BorderMouseDown">
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="Auto" />
					</Grid.ColumnDefinitions>
					<Image Grid.Column="0" Width="20" Height="20" Source="pack://application:,,,/Images/DisplaySettings.png"
					       VerticalAlignment="Center" HorizontalAlignment="Center" Margin="5,0,0,0" />
					<TextBlock Text="Display Settings" Grid.Column="1" Foreground="{DynamicResource TextColor}" FontFamily="Consolas"
					           FontSize="12" VerticalAlignment="Center" Margin="5,0,0,0" />
					<Button
						x:Name="DisplaySettingsButtonClose"
						ToolTip="Close"
						Grid.Column="4"
						Width="45"
						Style="{StaticResource CloseButtonStyle}"
						Tag="pack://application:,,,/Images/Close.png"
						Click="CloseButtonClick" />
				</Grid>
			</Border>
			<Border Grid.Row="1" Margin="10">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
					</Grid.RowDefinitions>
					<CheckBox
						IsChecked="True"
						Grid.Row="0"
						Content="Show full METAR"
						Margin="0,0,0,5"
						Style="{DynamicResource CheckBoxStyle}" />
				</Grid>
			</Border>
		</Grid>
	</Border>
</Window>