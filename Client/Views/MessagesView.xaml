<Window x:Class="Client.Views.MessagesView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Client.Views"
        mc:Ignorable="d"
        Width="600" Height="300"
        Cursor="Arrow"
        WindowStartupLocation="CenterScreen">
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0" CornerRadius="0" CaptionHeight="0"/>
    </WindowChrome.WindowChrome>
    <Border Background="Black">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Height="24" Background="{DynamicResource TitleBarColor}" MouseDown="BorderMouseDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Messages - Not connected" Grid.Column="0" Foreground="{DynamicResource TextColor}" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" Margin="5,0,0,0"/>
                    <Button
                        x:Name="MessagesCloseButton"
                        ToolTip="Close"
                        Grid.Column="1"
                        Width="45"
                        Style="{StaticResource CloseButtonStyle}"
                        Tag="pack://application:,,,/Images/Close.png"
                        Click="CloseButtonClick">
                    </Button>
                </Grid>
            </Border>
            <Border Grid.Row="1" Height="24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button
                        Grid.Column="0"
                        Width="50"
                        Content="ALL"
                        Background="Black"
                        BorderBrush="{DynamicResource GrayBorder}"
                        BorderThickness="1,1,1,0"
                        Foreground="{DynamicResource TextColor}"
                        Template="{DynamicResource MessageButtonTemplate}">
                    </Button>
                </Grid>
            </Border>
            <Border Name="MessageArea" Grid.Row="2" BorderBrush="{DynamicResource GrayBorder}" BorderThickness="1,1,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock
                        Name="MessageReceiveTextBox"
                        Grid.Row="0"
                        Margin="5"
                        Foreground="{DynamicResource YellowText}"
                        FontFamily="Consolas" FontWeight="Light" FontSize="12">
                    </TextBlock>
                </Grid>
            </Border>
            <Border Grid.Row="3" VerticalAlignment="Bottom" Height="24" BorderBrush="{DynamicResource GrayBorder}" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="75" BorderBrush="{DynamicResource GrayBorder}" BorderThickness="1,0,1,1"/>
                    <TextBox
                        Name="MessageSendTextBox"
                        Grid.Column="1"
                        Background="Black"
                        Foreground="{DynamicResource TextColor}"
                        BorderBrush="{DynamicResource GrayBorder}"
                        BorderThickness="0,0,1,1"
                        VerticalContentAlignment="Center"
                        FontFamily="Consolas" FontWeight="Light" FontSize="12"
                        TextChanged="MessageSendTextChanged"
                        KeyDown="MessageSendKeyDown"
                        Style="{DynamicResource TextBoxStyle}">
                    </TextBox>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
