<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <ControlTemplate x:Key="MenuButtonTemplate" TargetType="Button">
        <Grid>
            <Border x:Name="ButtonBorder" Background="Transparent" BorderThickness="0"/>
            <Grid>
                <Ellipse x:Name="RippleEffect" Fill="{DynamicResource BluePressed}" Opacity="0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource BlueMouseOver}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="RippleEffect" Storyboard.TargetProperty="Width" From="0" To="278" Duration="0:0:0.1"/>
                            <DoubleAnimation Storyboard.TargetName="RippleEffect" Storyboard.TargetProperty="Height" From="0" To="278" Duration="0:0:0.1"/>
                            <DoubleAnimation Storyboard.TargetName="RippleEffect" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.1"/>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="RippleEffect" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="MainButtonTemplate" TargetType="Button">
        <Grid>
            <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"/>
            <Grid>
                <Ellipse x:Name="RippleEffect" Fill="{DynamicResource BluePressed}" Opacity="0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource BlueMouseOver}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="RippleEffect" Storyboard.TargetProperty="Width" From="0" To="350" Duration="0:0:0.25"/>
                            <DoubleAnimation Storyboard.TargetName="RippleEffect" Storyboard.TargetProperty="Height" From="0" To="350" Duration="0:0:0.25"/>
                            <DoubleAnimation Storyboard.TargetName="RippleEffect" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25"/>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="RippleEffect" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="MessageButtonTemplate" TargetType="Button">
        <Grid>
            <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"/>
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>
    </ControlTemplate>

    <ControlTemplate x:Key="MainControlButtonTemplate" TargetType="ToggleButton">
        <Grid>
            <Border x:Name="Border" BorderBrush="{DynamicResource MainControlButtonGray}" BorderThickness="2,2,0,0" Background="{DynamicResource MainControlButtonBackground}" Margin="0,0,2,2">
                <Border x:Name="InnerBorder" BorderBrush="Black" BorderThickness="0,0,0,0" Margin="0,0,0,0"/>
            </Border>
            <ContentPresenter
                x:Name="ContentPresenter"
                Content="{TemplateBinding Content}"
                ContentTemplate="{TemplateBinding ContentTemplate}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                TextElement.Foreground="{TemplateBinding Foreground}">
            </ContentPresenter>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource MainControlButtonMouseOver}"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Border" Property="Background" Value="{DynamicResource MainControllButtonPressed}"/>
                <Setter TargetName="Border" Property="BorderBrush" Value="Black"/>
                <Setter TargetName="Border" Property="BorderThickness" Value="2,2,0,0"/>
                <Setter TargetName="Border" Property="Margin" Value="0,0,0,0"/>
                <Setter TargetName="InnerBorder" Property="BorderBrush" Value="{DynamicResource MainControlButtonGray}"/>
                <Setter TargetName="InnerBorder" Property="BorderThickness" Value="0,0,2,2"/>
                <Setter TargetName="InnerBorder" Property="Margin" Value="0,0,0,0"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="ComboBoxToggleButtonTemplate" TargetType="ToggleButton">
        <Grid>
            <Border x:Name="Border" Background="{DynamicResource GrayBackgroundLight}" BorderBrush="{DynamicResource GrayBorder}" BorderThickness="1"/>
            <Path x:Name="Arrow" Fill="{DynamicResource TextColor}" HorizontalAlignment="Right" VerticalAlignment="Center"
                  Margin="0,0,10,0" Data="M 0 0 L 4 4 L 8 0 Z"/>
        </Grid>
    </ControlTemplate>

</ResourceDictionary>